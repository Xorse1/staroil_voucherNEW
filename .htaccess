Options -Indexes -MultiViews
DirectoryIndex index.php

ServerSignature Off

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "(\.env$|composer\.(json|lock)$|package(-lock)?\.json$|yarn\.lock$|pnpm-lock\.yaml$|webpack\.config\.(js|cjs|mjs)$|vite\.config\.(js|ts|cjs|mjs)$|tailwind\.config\.(js|cjs|mjs)$|postcss\.config\.(js|cjs|mjs)$|phpunit\.xml$|README(\..*)?$|AGENTS\.md$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(bak|backup|old|orig|save|swp|swo|tmp|temp|dist|ini|conf|config|sql|sqlite|db|log|txt|md|yml|yaml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

RewriteEngine On

RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]
RewriteRule ^(\.git|\.svn|\.hg|\.agents|\.codex|vendor|node_modules|storage|logs?|tmp|cache|config|includes)(/|$) - [F,L]
RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|phpunit\.xml|web\.config)$ - [F,L]
RewriteRule (^|/).*\.(bak|backup|old|orig|save|swp|swo|tmp|temp|dist|ini|conf|config|sql|sqlite|db|log|txt|md|yml|yaml)$ - [F,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
